# ── FinanceAcademy (site de simulation) ───────────────────────────────────────
FINANCEACADEMY_URL=http://192.168.0.241:5000
BOT_EMAIL=bot@trading.com
BOT_PASSWORD=BotTrading2024!
BOT_USERNAME=TradingBot

# ── LM Studio (PC avec GPU — modifier l'IP) ───────────────────────────────────
LLM_BASE_URL=http://192.168.0.55:1234/v1
LLM_MODEL=qwen2.5-14b-instruct
LLM_API_KEY=lm-studio
LLM_TIMEOUT=120

# ── Paramètres de trading ─────────────────────────────────────────────────────
# Taille max par position (% du portfolio total)
MAX_POSITION_PCT=5.0
# Nombre max de positions ouvertes simultanément
MAX_POSITIONS=12
# Cash minimum à conserver (% du portfolio)
MIN_CASH_PCT_BULL=10.0
MIN_CASH_PCT_BEAR=40.0
MIN_CASH_PCT_NEUTRAL=20.0
# Perte journalière max avant arrêt total des trades (%)
MAX_DAILY_LOSS_PCT=4.0
# Stop loss par défaut (% sous le prix d'achat)
DEFAULT_STOP_LOSS_PCT=6.0
# Nombre de stocks candidats envoyés au LLM par cycle
TOP_STOCKS_COUNT=20

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log
